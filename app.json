{
  "expo": {
    "name": "Herblore",
    "slug": "herblore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "herblore",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1612"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.herblore.app",
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-font"
    ]
  }
}
